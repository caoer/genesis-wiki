filters:
  and:
    - file.inFolder("sessions")
    - file.hasProperty("state")
views:
  - type: table
    name: Board
    groupBy:
      property: state
      direction: ASC
    order:
      - file.name
      - state
      - file.folder
  - type: cards
    name: Kanban
    groupBy:
      property: state
      direction: ASC
    order:
      - file.name
      - file.folder
